{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@assets/*": ["./src/assets/*"],
            "@components/*": ["./src/components/*"],
            "@ui/*": ["./src/components/ui/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@styles/*": ["./src/styles/*"]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "react"
    }
}
